# Staging-dataset env file for manual script invocation.
# Source this file or set these vars before running individual eval scripts.
# Assumes the dataset is placed at $DATA_DIR (default: <repo>/data).
#
# Usage:
#   DATA_DIR=/path/to/anonymous-dataset
#   source reproduction/eval_paths.env
#   uv run python src/evaluation/neurips/m1_funnel.py

DATA_DIR=${DATA_DIR:-$(dirname "$0")/../data}

V4_LOGS=$DATA_DIR/replay_logs/full_scene
V2_LOGS=$DATA_DIR/replay_logs/behavior_only
NS_LOGS=$DATA_DIR/replay_logs/no_schema

V4_JSONL_GLOB=$DATA_DIR/generation_outputs/v4_ir/*.jsonl
V2_JSONL_GLOB=$DATA_DIR/generation_outputs/v2_ir/*.jsonl
NS_JSONL_GLOB=$DATA_DIR/generation_outputs/no_schema/*.jsonl

export V4_LOGS V2_LOGS NS_LOGS V4_JSONL_GLOB V2_JSONL_GLOB NS_JSONL_GLOB
